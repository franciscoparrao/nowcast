# nowcast-monitor — configuración (shell-sourceable; la lee monitor.sh y el fetcher)
#
# Piloto por defecto: cordillera de la RM / Cajón del Maipo, forzante IMERG
# Early NRT (~4 h de latencia, 30 min / 0.1°), susceptibilidad uniforme 1.0
# (monitor de TIMING: el peligro se reduce al factor de gatillo I-D).
# Cuando exista el raster de susceptibilidad regenerado, apuntar SUSC_TIF.

# --- Dominio (bbox en grados, WGS84: W,S,E,N) --------------------------------
BBOX="-70.75,-34.25,-69.75,-33.25"

# --- Directorio de trabajo (datos rotativos, estado, logs) -------------------
WORK_DIR="${WORK_DIR:-$HOME/nowcast-monitor}"

# --- Motor -------------------------------------------------------------------
# Binario del CLI (compilar con: cargo build --release -p nowcast-cli)
NOWCAST_BIN="${NOWCAST_BIN:-$HOME/nowcast-monitor/bin/nowcast}"
# Umbral I-D (default: Caine 1980 global — el que validó los 3 eventos IMERG).
ID_A=14.82
ID_B=0.39
K=4.0
# Paso IMERG semihorario ⇒ 0.5 h. max_window en PASOS: 96 = ventana I-D de 48 h.
DT_HOURS=0.5
MAX_WINDOW=96
ALERT_LEVEL=0.5
# Calibrador JSON opcional (de `nowcast calibrate`); vacío = índice crudo.
CALIBRATOR=""
# Susceptibilidad: GeoTIFF en [0,1] con la MISMA grilla del dominio IMERG, o
# vacío para uniforme 1.0 (monitor de timing).
SUSC_TIF=""

# --- Ventana rodante (sin estado: cada ciclo re-corre la ventana completa) ---
# Debe cubrir max_window: 96 pasos × 0.5 h = 48 h; margen para la latencia NRT.
WINDOW_HOURS=54
# Mínimo de pasos para correr (si hay menos, se notifica DEGRADED y no se corre).
MIN_STEPS=96

# --- Salud del feed ----------------------------------------------------------
# IMERG Early publica con ~4 h de retraso; más viejo que esto = feed STALE.
STALE_HOURS=6
# Máxima fracción de pasos rellenados con cero (huecos) antes de DEGRADED.
MAX_GAP_FRACTION=0.10

# --- Fase A: feeds adicionales fusionados por noisy-OR ------------------------
# Cada feed vive en $WORK_DIR/feeds/<nombre>/steps con el mismo contrato que
# IMERG (step_*.tif + gapmark_* + status.json). La fusión corre sobre la UNIÓN
# de ventanas: los pasos donde un feed no tiene dato entran como cero (no
# aportan al noisy-OR) y el relleno se cuenta y loguea — ver prepare_fusion.py.

# GOES-East QPE (ABI-L2-RRQPEF, 10 min, latencia ~minutos, bucket AWS público).
GOES_ENABLED=1
GOES_BUCKET="noaa-goes19"
# El feed GOES publica en minutos: más viejo que esto = feed GOES caído.
GOES_STALE_HOURS=1

# Pluviómetros in-situ vía API DMC (Servicios Climáticos). REGISTRO GRATUITO:
# https://climatologia.meteochile.gob.cl/application/usuario/registroUsuario
# → la API key aparece en el perfil. Las credenciales NO van aquí (este
# archivo se versiona en un repo público): van en config.local.env (mismo
# directorio, gitignored — monitor.sh lo sourcea encima de este). Sin token
# el feed se deshabilita solo y la fusión sigue con IMERG+GOES.
DGA_ENABLED=1
DMC_USUARIO=""
DMC_TOKEN=""
# Estaciones codigo:lon:lat:nombre separadas por coma. Vacío = defaults de
# fetch_dga.py: EMAs DMC del dominio con pluviómetro minutario verificado
# (El Colorado 2750m, San José Guayacán, La Florida). NOTA: los códigos DGA
# republicados (El Yeso 330149, etc.) responden "Información no disponible"
# en esta API — la DMC publica su metadata, no sus datos (2026-07-11).
DGA_STATIONS=""
# Los registros minutarios de la API llegan con ~20-60 min de retraso.
DGA_STALE_HOURS=3

# Regla de combinación de los gatillos fusionados (noisy-or | max | product).
COMBINE="noisy-or"

# --- Notificaciones (ntfy.sh; vacío = solo log) ------------------------------
NTFY_URL="https://ntfy.sh"
NTFY_TOPIC=""
# Histéresis: re-notificar una alerta que persiste cada N horas.
REALERT_HOURS=6
# Histéresis del aviso de feed caído.
RESTALE_HOURS=12

# --- Salidas opcionales ------------------------------------------------------
# 1 = escribir GeoTIFFs de peligro del último paso en $WORK_DIR/out (disco!).
WRITE_HAZARD_TIFS=0
