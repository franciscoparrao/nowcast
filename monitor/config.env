# nowcast-monitor — configuración (shell-sourceable; la lee monitor.sh y el fetcher)
#
# Piloto por defecto: cordillera de la RM / Cajón del Maipo, forzante IMERG
# Early NRT (~4 h de latencia, 30 min / 0.1°), susceptibilidad uniforme 1.0
# (monitor de TIMING: el peligro se reduce al factor de gatillo I-D).
# Cuando exista el raster de susceptibilidad regenerado, apuntar SUSC_TIF.

# --- Dominio (bbox en grados, WGS84: W,S,E,N) --------------------------------
BBOX="-70.75,-34.25,-69.75,-33.25"

# --- Directorio de trabajo (datos rotativos, estado, logs) -------------------
WORK_DIR="${WORK_DIR:-$HOME/nowcast-monitor}"

# --- Motor -------------------------------------------------------------------
# Binario del CLI (compilar con: cargo build --release -p nowcast-cli)
NOWCAST_BIN="${NOWCAST_BIN:-$HOME/nowcast-monitor/bin/nowcast}"
# Umbral I-D (default: Caine 1980 global — el que validó los 3 eventos IMERG).
ID_A=14.82
ID_B=0.39
K=4.0
# Paso IMERG semihorario ⇒ 0.5 h. max_window en PASOS: 96 = ventana I-D de 48 h.
DT_HOURS=0.5
MAX_WINDOW=96
ALERT_LEVEL=0.5
# Calibrador JSON opcional (de `nowcast calibrate`); vacío = índice crudo.
CALIBRATOR=""
# Susceptibilidad: GeoTIFF en [0,1] con la MISMA grilla del dominio IMERG, o
# vacío para uniforme 1.0 (monitor de timing).
SUSC_TIF=""

# --- Ventana rodante (sin estado: cada ciclo re-corre la ventana completa) ---
# Debe cubrir max_window: 96 pasos × 0.5 h = 48 h; margen para la latencia NRT.
WINDOW_HOURS=54
# Mínimo de pasos para correr (si hay menos, se notifica DEGRADED y no se corre).
MIN_STEPS=96

# --- Salud del feed ----------------------------------------------------------
# IMERG Early publica con ~4 h de retraso; más viejo que esto = feed STALE.
STALE_HOURS=6
# Máxima fracción de pasos rellenados con cero (huecos) antes de DEGRADED.
MAX_GAP_FRACTION=0.10

# --- Notificaciones (ntfy.sh; vacío = solo log) ------------------------------
NTFY_URL="https://ntfy.sh"
NTFY_TOPIC=""
# Histéresis: re-notificar una alerta que persiste cada N horas.
REALERT_HOURS=6
# Histéresis del aviso de feed caído.
RESTALE_HOURS=12

# --- Salidas opcionales ------------------------------------------------------
# 1 = escribir GeoTIFFs de peligro del último paso en $WORK_DIR/out (disco!).
WRITE_HAZARD_TIFS=0
